---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, featured, ...props } = data;
---

<li class:list={["my-6", { "border-l-2 border-accent pl-3": featured }]}>
  <div class="flex items-baseline gap-2 flex-wrap">
    <a
      href={getPath(id, filePath)}
      class:list={[
        "inline-block text-lg font-medium text-accent",
        "decoration-dashed underline-offset-4 hover:underline",
        "focus-visible:no-underline focus-visible:underline-offset-0",
      ]}
    >
      <Heading
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
      >
        {title}
      </Heading>
    </a>
    {
      featured && (
        <span class="text-xs font-mono font-medium text-accent/80 border border-accent/40 rounded px-1.5 py-0.5 leading-none">
          pinned
        </span>
      )
    }
  </div>
  <Datetime {...props} />
  <p>{description}</p>
</li>
