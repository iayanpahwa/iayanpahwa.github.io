---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import { PUBLIC_WEB3FORMS_KEY } from "astro:env/client";
---

<Layout title={`Contact | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout pb-12">
    <h1 class="mt-8 mb-2 text-2xl font-bold text-accent sm:text-3xl">
      Contact
    </h1>
    <p class="mb-4 opacity-75">Got something interesting? Drop me a message using form below or <a href="mailto:website.contact@codensolder.com" class="text-accent hover:underline">email</a>.</p>

    <p class="mb-1 opacity-75">If you wish to send me an encrypted message, my PGP public key is available at <a href="/pgp.asc" download class="text-accent hover:underline">/pgp.asc</a>.</p>
    <p class="mb-8 font-mono text-sm opacity-60">Fingerprint: 97CE 3B9E 75CF F9C7 6B9F&nbsp;&nbsp;C0A2 D87D 45E4 CCC3 57A7</p>

    <div id="form-wrap">
      <!--
        method="POST" + no action = submits to current page as POST if JS fails.
        No hidden fields — access_key lives only in the JS fetch body below.
      -->
      <form
        id="contact-form"
        method="POST"
        data-key={PUBLIC_WEB3FORMS_KEY}
        class="flex flex-col gap-5 max-w-lg"
      >
        <div class="flex flex-col gap-1.5">
          <label for="name" class="text-sm font-medium opacity-80">Name</label>
          <input
            id="name"
            type="text"
            name="name"
            required
            placeholder="Your name"
            class="rounded border border-border bg-muted/40 px-4 py-2.5 text-foreground placeholder:opacity-40 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="email" class="text-sm font-medium opacity-80">Email</label>
          <input
            id="email"
            type="email"
            name="email"
            required
            placeholder="your@email.com"
            class="rounded border border-border bg-muted/40 px-4 py-2.5 text-foreground placeholder:opacity-40 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="query" class="text-sm font-medium opacity-80">Query</label>
          <textarea
            id="query"
            name="message"
            required
            rows={5}
            placeholder="What's on your mind?"
            class="rounded border border-border bg-muted/40 px-4 py-2.5 text-foreground placeholder:opacity-40 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent resize-y"
          ></textarea>
        </div>

        <button
          id="submit-btn"
          type="submit"
          class="self-start rounded border border-accent px-6 py-2.5 font-medium text-accent transition-colors hover:bg-accent hover:text-background focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Send Message
        </button>
      </form>
    </div>

    <div id="success-msg" class="hidden mt-4 rounded border border-border bg-muted/40 px-6 py-5 max-w-lg">
      <p class="text-foreground">
        Thanks for contacting me, I'll be in touch if I find your query relevant.
      </p>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const wrap = document.getElementById("form-wrap");
  const success = document.getElementById("success-msg");
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = "Sending…";

    const fd = new FormData(form);

    try {
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify({
          access_key: form.dataset.key,
          subject: "New message from CodeNSolder contact form",
          name: fd.get("name"),
          email: fd.get("email"),
          message: fd.get("message"),
        }),
      });
      const json = await res.json();

      if (json.success) {
        wrap?.classList.add("hidden");
        success?.classList.remove("hidden");
      } else {
        btn.textContent = "Failed — try again";
        btn.disabled = false;
      }
    } catch {
      btn.textContent = "Failed — try again";
      btn.disabled = false;
    }
  });
</script>
