---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import SortToggle from "@/components/SortToggle.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts, "published");
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

// Metadata for all non-featured posts (used by client-side sort toggle)
const allNonFeaturedMeta = recentPosts.map(p => ({
  title: p.data.title,
  url: getPath(p.id, p.filePath),
  description: p.data.description,
  pubDatetime: p.data.pubDatetime.toISOString(),
  modDatetime: p.data.modDatetime?.toISOString() ?? null,
}));
---

<Layout pageType="home">
  <Header />
  <main id="main-content" data-layout="index" data-post-per-index={SITE.postPerIndex} class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <div class="my-4 flex items-center gap-4 sm:my-8">
        <img
          src="/optimized/assets/images/avatar.webp"
          alt="Ayan Pahwa"
          width="72"
          height="72"
          class="size-14 rounded-full object-cover ring-2 ring-border sm:size-[72px]"
        />
        <div class="flex items-center gap-3">
          <h1 class="inline-block text-3xl font-bold sm:text-5xl">
            Ayan Pahwa
          </h1>
          <a
            target="_blank"
            href="/rss.xml"
            class="inline-block"
            aria-label="rss feed"
            title="RSS Feed"
          >
            <IconRss
              width={20}
              height={20}
              class="scale-125 stroke-accent stroke-3"
            />
            <span class="sr-only">RSS Feed</span>
          </a>
        </div>
      </div>
      <p class="mb-4 max-w-xl text-sm leading-relaxed text-foreground/70 sm:text-base">
        A tech flâneur, long on self-hosting, privacy-respecting tools, and everyday carry; dad of two, coffee nerd, and a constant tinkerer, trying to live a life driven by curiosity and many parallel expensive interests & hobbies
      </p>
      {
        SOCIALS.length > 0 && (
          <div class="mt-4">
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">📌 Pinned Blogs</h2>
          <ul>
            {featuredPosts.slice(0, 4).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <div class="flex items-center justify-between mb-1">
            <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
            <SortToggle />
          </div>
          <ul id="recent-posts-list">
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div id="non-featured-meta" data-posts={JSON.stringify(allNonFeaturedMeta)} hidden></div>

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE.author,
    url: `${SITE.website}about/`,
    image: `${SITE.website}optimized/assets/images/avatar.webp`,
    description: SITE.desc,
    sameAs: [
      "https://github.com/iAyanPahwa",
      "https://x.com/iayanpahwa",
      "https://linkedin.com/in/iAyanPahwa",
    ],
  })}
/>

<script>
  const MONTHS = [
    "Jan","Feb","Mar","Apr","May","Jun",
    "Jul","Aug","Sep","Oct","Nov","Dec",
  ];

  function formatDate(iso: string) {
    const d = new Date(iso);
    return `${d.getUTCDate()} ${MONTHS[d.getUTCMonth()]}, ${d.getUTCFullYear()}`;
  }

  function renderCard(p: {
    title: string;
    url: string;
    description: string;
    pubDatetime: string;
    modDatetime: string | null;
  }, sortBy: string) {
    const isModified =
      sortBy === "modified" &&
      p.modDatetime != null &&
      p.modDatetime > p.pubDatetime;
    const displayDate = formatDate(isModified ? p.modDatetime! : p.pubDatetime);
    return `<li class="my-6">
      <a href="${p.url}" class="inline-block text-lg font-medium text-accent decoration-dashed underline-offset-4 hover:underline">
        <h3>${p.title}</h3>
      </a>
      <div class="flex items-center gap-x-2 opacity-80">
        ${isModified ? '<span class="text-sm">Updated:</span>' : ""}
        <time class="text-sm">${displayDate}</time>
      </div>
      <p>${p.description}</p>
    </li>`;
  }

  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }

    const metaEl = document.getElementById("non-featured-meta") as HTMLElement | null;
    if (!metaEl) return;

    const allPosts: {
      title: string;
      url: string;
      description: string;
      pubDatetime: string;
      modDatetime: string | null;
    }[] = JSON.parse(metaEl.dataset.posts ?? "[]");

    const mainEl = document.querySelector("#main-content") as HTMLElement;
    const postPerIndex = parseInt(mainEl?.dataset?.postPerIndex ?? "5");

    document.addEventListener("sort-change", (e: Event) => {
      const sortBy = (e as CustomEvent<string>).detail;
      const list = document.getElementById("recent-posts-list");
      if (!list) return;

      const sorted = [...allPosts].sort((a, b) => {
        const da =
          sortBy === "modified"
            ? new Date(a.modDatetime ?? a.pubDatetime).getTime()
            : new Date(a.pubDatetime).getTime();
        const db =
          sortBy === "modified"
            ? new Date(b.modDatetime ?? b.pubDatetime).getTime()
            : new Date(b.pubDatetime).getTime();
        return db - da;
      });

      list.innerHTML = sorted
        .slice(0, postPerIndex || 5)
        .map(p => renderCard(p, sortBy))
        .join("");
    });
  });
</script>
